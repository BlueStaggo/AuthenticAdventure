+        this(new byte[size]);
+    }
+
+    public BitArray(byte[] data) {
+        this.data = data;
+        this.length = data.length;
+        this.bitLength = data.length << 3;
+    }
+
+    public boolean get(int i) {
+        if(i >= this.bitLength || i < 0) {
+            throw new ArrayIndexOutOfBoundsException(i);
+        }
+        return ((this.data[i >> 3] >>> (i & 7)) & 1) == 1;
+    }
