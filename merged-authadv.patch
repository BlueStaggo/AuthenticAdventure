+package net.minecraft.client.render.texture;
+
+import net.minecraft.client.Minecraft;
+import net.minecraft.client.resource.pack.TexturePack;
+import net.minecraft.client.resource.pack.TexturePacks;
+import net.minecraft.util.math.MathHelper;
+
+import javax.imageio.ImageIO;
+import java.awt.image.BufferedImage;
+import java.io.IOException;
+import java.util.Random;
+
+public class CosmiteSprite extends DynamicTexture {
+    private static final int[] overlayTexture = new int[65536];
+    private static boolean overlayLoaded;
+
+    private final Random random;
+    private final int[] baseTexture = new int[256];
+    private final float[] yOffsets = new float[16];
+    private final int[] depths = new int[16];
+    private final int[] xOffsets = new int[16];
+
+    public CosmiteSprite(int sprite, int altas, TexturePack texturePack) {
+        super(sprite);
+        this.atlas = altas;
+        this.random = new Random();
+
+        if(!overlayLoaded) {
+            try {
+                BufferedImage overlayImage = ImageIO.read(Minecraft.class.getResource("/misc/cosmitefield.png"));
+                overlayImage.getRGB(0, 0, 256, 256, overlayTexture, 0, 256);
+            } catch (IOException exception) {
+                exception.printStackTrace();
+            }
+            overlayLoaded = true;
+        }
+
+        try {
+            BufferedImage itemsImage = ImageIO.read(
+                texturePack.getResource(this.atlas == 1 ? "/gui/items.png" : "/terrain.png"));
+            int spriteX = this.sprite % 16 * 16;
+            int spriteY = this.sprite / 16 * 16;
+            itemsImage.getRGB(spriteX, spriteY, 16, 16, this.baseTexture, 0, 16);
+        } catch (IOException exception) {
+            exception.printStackTrace();
+        }
+
+        for(int i = 0; i < 16; i++) {
+            this.depths[i] = this.random.nextInt(4);
+            this.xOffsets[i] = this.random.nextInt(256);
+        }
+    }
+
+    public void tick() {
+        for(int i = 0; i < 16; i++) {
+            int depth = this.depths[i];
+            this.yOffsets[i] += 1.0F / (depth + 1.0F);
+            if(this.yOffsets[i] > 256.0F) {
+                this.yOffsets[i] = 0.0F;
+                this.depths[i] = this.random.nextInt(4);
+                this.xOffsets[i] = this.random.nextInt(256);
+            }
+        }
+
+        for(int i = 0; i < 256; i++) {
+            int a = this.baseTexture[i] >> 24 & 0xFF;
+            if(a == 0) {
+                this.pixels[i * 4 + 3] = 0;
+                continue;
+            }
+
+            int x = i % 16;
+            int y = i / 16;
+
+            int overlayX = this.xOffsets[x];
+            int overlayY = Math.floorMod(y + (int)this.yOffsets[x], 256);
+            int overlayI = overlayX + overlayY * 256;
+            int depth = this.depths[x];
+
+            int r = this.baseTexture[i] >> 16 & 0xFF;
+            int g = this.baseTexture[i] >> 8 & 0xFF;
+            int b = this.baseTexture[i] & 0xFF;
+
+            int overlayR = overlayTexture[overlayI] >> 16 & 0xFF;
+            int overlayG = overlayTexture[overlayI] >> 8 & 0xFF;
+            int overlayB = overlayTexture[overlayI] & 0xFF;
+
+            r = MathHelper.clamp(r + overlayR / (depth + 1), 0, 255);
+            g = MathHelper.clamp(g + overlayG / (depth + 1), 0, 255);
+            b = MathHelper.clamp(b + overlayB / (depth + 1), 0, 255);
+
+            this.pixels[i * 4] = (byte)r;
+            this.pixels[i * 4 + 1] = (byte)g;
+            this.pixels[i * 4 + 2] = (byte)b;
+            this.pixels[i * 4 + 3] = (byte)a;
+        }
+    }
+}
